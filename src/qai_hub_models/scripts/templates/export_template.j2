        Each component is compiled and profiled separately.
        Defaults to all components of the CollectionModel if not specified.
    {%- endif %}
    {%- if not is_precompiled  %}
    precision
        The precision to which this model should be quantized.
        Quantization is skipped if the precision is float.
    {%- endif %}
    {%- if can_use_quantize_job %}
    num_calibration_samples
        The number of calibration data samples
        to use for quantization. If not set, uses the default number
        specified by the dataset. If model doesn't have a calibration dataset
        specified, this must be None.
    quantized_model_id
        A quantized ONNX hub model id, skips quantizing model.
    skip_compiling
        If set, skips compiling of model to format that can run on device.
    {%- endif %}
    skip_profiling
        If set, skips profiling of compiled model on real devices.
    {%- if not is_precompiled  %}
    skip_inferencing
        If set, skips computing on-device outputs from sample data.
    {%- endif %}
    skip_downloading
        If set, skips downloading of compiled model.
    skip_summary
        If set, skips waiting for and summarizing results
        from profiling{{ " and inference" if not is_precompiled else "" }}.
    output_dir
        Directory to store generated assets (e.g. compiled model).
        Defaults to `<cwd>/export_assets`.
    {%- if not is_precompiled %}
    target_runtime
        Which on-device runtime to target. Default is TFLite.
    compile_options
        Additional options to pass when submitting the compile job.
    {%- endif %}
    {%- if can_use_quantize_job %}
    quantize_options
        Additional options to pass when submitting the quantize job.
    {%- endif %}
    profile_options
        Additional options to pass when submitting the profile job.
    fetch_static_assets
        If set, known assets are fetched from the given version rather than re-computing them. Can be passed as "latest" or "v<version>".
    zip_assets
        If set, zip the assets after downloading.
    **additional_model_kwargs
        Additional optional kwargs used to customize
        `model_cls.from_pre{{ "compiled" if is_precompiled else "trained" }}`
        {{- "" if is_collection_model else " and `model.get_input_spec`" }}
        {{- " and per-component `get_input_spec`" if is_collection_model else "" }}

    Returns
    -------
    {%- if is_collection_model %}
    CollectionExportResult
        A Mapping from component_name to:
    {%- else %}
    ExportResult
    {%- endif %}
        {%- filter indent(width=4 if is_collection_model else 0) %}
        {%- if not is_precompiled %}
        * A CompileJob object containing metadata about the compile job submitted to hub{{ " (None if compiling skipped)" if can_use_quantize_job else "" }}.
        * An InferenceJob containing metadata about the inference job (None if inferencing skipped).
        {%- endif %}
        * A ProfileJob containing metadata about the profile job (None if profiling skipped).
        {%- if can_use_quantize_job %}
        * A QuantizeJob object containing metadata about the quantize job submitted to hub
        {%- endif %}
        {%- endfilter %}
        * The path to the downloaded model folder (or zip), or None if one or more of: skip_downloading is True, fetch_static_assets is set, or AI Hub Workbench is not accessible
    """
    model_name = {{ "MODEL_ID" if is_precompiled else "get_export_model_name(Model, MODEL_ID, precision, additional_model_kwargs)" }}

    output_path = Path(output_dir or Path.cwd() / "export_assets")
    {%- if is_precompiled %}
    precision = {{ "Precision." + default_aihub_job_precision }}
    target_runtime = TargetRuntime.QNN_CONTEXT_BINARY
    {% endif -%}
    {%- if not is_precompiled and not can_use_quantize_job %}
    assert precision in [{% for precision in supported_precisions %}{{ "Precision." + precision.__str__() }},{% endfor %}], f"Precision {str(precision)} is not supported by {model_name}"
    {%- endif %}
    {%- if is_collection_model %}
    component_arg = components
    components = components or Model.component_class_names
    for component_name in components:
        if component_name not in Model.component_class_names:
            raise ValueError(f"Invalid component {component_name}.")
    {%- endif %}
    {% if model_display_name is defined -%}
    if fetch_static_assets or not can_access_qualcomm_ai_hub():
        static_model_path = export_without_hub_access(
            MODEL_ID,
            device,
            skip_profiling,
            {{ "skip_inferencing" if not is_precompiled else "True" }},
            skip_downloading,
            skip_summary,
            output_path,
            target_runtime,
            precision,
            {{ "quantize_options + " if can_use_quantize_job else "" }}{{ "compile_options + " if not is_precompiled else "" }}profile_options,
            {%- if is_collection_model %}component_arg,{%- endif %}
            qaihm_version_tag=fetch_static_assets,
        )
        return {{ "ExportResult(download_path=static_model_path)" if not is_collection_model else "CollectionExportResult(components={component_name: ExportResult() for component_name in components}, download_path=static_model_path)" }}

    {% endif -%}
    hub_device = hub.get_devices(name=device.name, attributes=device.attributes, os=device.os)[-1]
    chipset_attr = next((attr for attr in hub_device.attributes if "chipset" in attr), None)
    chipset = chipset_attr.split(":")[-1] if chipset_attr else None

    # {{ steps.init }}
    {%- if is_precompiled %}
    print("Initializing model class")
    model = Model.from_precompiled()
    {%- else %}
    model = Model.from_pretrained(**get_model_kwargs(Model, dict(**additional_model_kwargs, precision=precision)))
    {%- endif %}

    {%- if is_precompiled %}

    # {{ steps.upload }}
    uploaded_models: dict[str, hub.Model] = {}
    if not skip_profiling{{ " or not skip_inferencing" if not is_precompiled else ""}}:
        print("Uploading model assets on hub")
        for component_name in components:
            path = cast(BasePrecompiledModel, model.components[component_name]).get_target_model_path()
            uploaded_models[component_name] = hub.upload_model(path)
    {%- else %}

    {%- if not is_collection_model %}
    input_spec = model.get_input_spec(
        **get_input_spec_kwargs(model, additional_model_kwargs)
    )
    {%- else %}
    input_specs: dict[str, InputSpec] = {
        name: model.components[name].get_input_spec(
            **get_component_input_spec_kwargs(Model, name, additional_model_kwargs)
        )
        for name in components
    }
    {%- endif %}
    {% if can_use_quantize_job %}
    # {{ steps.quantize }}
    quantize_job{{ optional_s }}{{ ": dict[str, hub.client.QuantizeJob] = {}" if is_collection_model else ": hub.client.QuantizeJob | None = None" }}
    quantized_model{{ optional_s }}: {{ "dict[str, hub.Model] | None" if is_collection_model else "hub.Model | None" }} = None
    if precision != Precision.float:
        if quantized_model_id:
            {%- if is_collection_model %}
            quantized_models = {
                component: hub_model
                for component in components
                if (hub_model := hub.get_model(quantized_model_id[component])) is not None
            }
            {%- else %}
            quantized_model = hub.get_model(quantized_model_id)
            assert quantized_model is not None
            {%- endif %}
        else:
            {%- if is_collection_model %}
            component_precisions = model.get_component_precisions(precision)
            {%- endif %}
            onnx_compile_job{{ optional_s }} = compile_model(
                model,
                model_name,
                device,
                TargetRuntime.ONNX,
                precision,
                {%- if not is_collection_model %}
                input_spec=input_spec,
                {%- else %}
                input_specs=input_specs,
                components=[c for c, p in component_precisions.items() if c in components and p != Precision.float],
                {%- endif %}
            )
            {%- if is_collection_model %}
            onnx_models = assert_success_and_get_target_models(onnx_compile_jobs)
            {%- else %}
            onnx_model = onnx_compile_job.get_target_model()
            assert onnx_model is not None, f"ONNX compile job failed: {onnx_compile_job}"
            {%- endif %}
            quantize_job{{ optional_s }} = quantize_model(
                {{ "component_precisions" if is_collection_model else "precision" }},
                model,
                model_name,
                onnx_model{{ optional_s }},
                num_calibration_samples,
                {%- if is_collection_model %}
                quantize_options,
                input_specs,
                components,
                {%- else %}
                quantize_options,
                input_spec,
                {%- endif %}
            )
            if skip_compiling:
                {%- if is_collection_model %}
                return CollectionExportResult(
                    components={
                        component_name: ExportResult(quantize_job=quantize_jobs.get(component_name))
                        for component_name in components
                    },
                )
                {%- else %}
                return ExportResult(quantize_job=quantize_job)
                {%- endif -%}
            {%- if is_collection_model %}
            quantized_models = assert_success_and_get_target_models(quantize_jobs)
            {%- else %}
            quantized_model = quantize_job.get_target_model()
            assert quantized_model is not None, f"Quantize job failed: {quantize_job}"
            {%- endif %}
    {%- endif %}

    # {{ steps.compile }}
    compile_job{{ optional_s }}{{ ": dict[str, hub.client.CompileJob]" if is_collection_model else "" }} = compile_model(
        model,
        model_name,
        device,
        target_runtime,
        {%- if can_use_quantize_job %}
        precision,
        quantized_model{{ optional_s }},
        {%- endif %}
        {%- if is_aimet %}
        output_path=output_path,
        {%- endif %}
        {%- if not is_collection_model %}
        input_spec=input_spec,
        {%- else %}
        input_specs=input_specs,
        components=components,
        {%- endif %}
        extra_options=compile_options,
    )

    # {{ steps.link }}
    link_job{{ optional_s }}{{ ": dict[str, hub.client.LinkJob]" if is_collection_model else ": hub.client.LinkJob" }} | None = None
    target_model{{ optional_s }}: {{ "dict[str, hub.Model]" if is_collection_model else "hub.Model | None" }}
    if target_runtime.uses_hub_link:
        {%- if is_collection_model %}
        compiled_models = assert_success_and_get_target_models(compile_jobs)
        {%- else %}
        compiled_model = compile_job.get_target_model()
        assert compiled_model is not None, f"Compile job failed: {compile_job}"
        {%- endif %}
        link_job{{ optional_s }} = link_model(
            compiled_model{{ optional_s }},
            device,
            model_name,
            model,
            target_runtime,
        )
        {%- if not is_collection_model %}
        # Extract target models from link jobs for profile/inference
        target_model = link_job.get_target_model()
        assert target_model is not None, f"Link job failed: {link_job}"
        {%- endif %}
    {%- if not is_collection_model %}
    else:
        # For JIT runtimes, extract models from compile jobs
        target_model = compile_job.get_target_model()
        assert target_model is not None, f"Compile job failed: {compile_job}"
    {%- endif %}
    {%- if is_collection_model %}
    target_models = assert_success_and_get_target_models(link_jobs if link_jobs else compile_jobs)
    {%- endif %}
    {%- endif %}

    # {{ steps.profile }}
    profile_job{{ optional_s }}{{ ": dict[str, hub.client.ProfileJob] = {}" if is_collection_model else " : hub.client.ProfileJob | None = None" }}
    if not skip_profiling:
        profile_job{{ optional_s }} = profile_model(
            model_name,
            device,
            model.get_hub_profile_options(target_runtime, profile_options),
            {%- if is_precompiled %}
            uploaded_models,
            {%- else %}
            target_model{{ optional_s }},
            {%- endif %}
            {%- if is_collection_model %}
            components,
            {%- endif %}
        )

    {% if not is_precompiled %}
    # {{ steps.inference }}
    inference_job{{ optional_s }}{{ " : dict[str, hub.client.InferenceJob] = {}" if is_collection_model else " : hub.client.InferenceJob | None = None" }}
    if not skip_inferencing:
        inference_job{{ optional_s }} = inference_model(
            model.sample_inputs(
                {{ "input_spec" if not is_collection_model else "input_specs" }}={{ "input_spec" if not is_collection_model else "input_specs" }},
                use_channel_last_format=target_runtime.channel_last_native_execution
            ),
            model_name,
            device,
            model.get_hub_profile_options(target_runtime, profile_options),
            {%- if is_precompiled %}
            uploaded_models,
            {%- else %}
            target_model{{ optional_s }},
            {%- endif %}
            {%- if is_collection_model %}
            components,
            {%- endif %}
        )
    {%- endif %}

    # {{ steps.tool_versions }}
    tool_versions: ToolVersions | None = None
    tool_versions_are_from_device_job = False
    if not skip_summary{% if not is_precompiled %} or not skip_downloading{% endif %}:
        {%- if is_collection_model %}
        profile_job = next(iter(profile_jobs.values())) if profile_jobs else None
        {%- if not is_precompiled %}
        inference_job = next(iter(inference_jobs.values())) if inference_jobs else None
        compile_job = next(iter(compile_jobs.values())) if compile_jobs else None
        {%- endif %}
        {%- endif %}
        if profile_job is not None and profile_job.wait():
            tool_versions = ToolVersions.from_job(profile_job)
            tool_versions_are_from_device_job = True
        {%- if not is_precompiled %}
        elif inference_job is not None and inference_job.wait():
            tool_versions = ToolVersions.from_job(inference_job)
            tool_versions_are_from_device_job = True
        elif compile_job and compile_job.wait():
            tool_versions = ToolVersions.from_job(compile_job)
        {%- endif %}

    # {{ steps.download }}
    downloaded_model_path : Path | None = None
    if not skip_downloading{% if not is_precompiled %} and tool_versions is not None{% endif %}:
        model_directory = output_path / ASSET_CONFIG.get_release_asset_name(MODEL_ID, target_runtime, precision, chipset)
        {%- if not is_precompiled %}
        downloaded_model_path = download_model(
            model_directory,
            model,
            target_runtime,
            precision,
            tool_versions,
            {{ "target_models" if is_collection_model else "target_model" }}{{ "" if is_collection_model else ", MODEL_ID" }},
            zip_assets
        )
        {%- else %}
        downloaded_model_path = save_model(model_directory, tool_versions, model, {{ "components, " if is_collection_model else "" }}zip_assets)
        {%- endif %}


    # {{ steps.summary }}
    if not skip_summary and {{ "not skip_profiling" if is_collection_model else "profile_job is not None" }}:
        {%- if is_collection_model %}
        for component_name in components:
            profile_job = profile_jobs[component_name]
        {%- endif %}
        {%- filter indent(width=4 if is_collection_model else 0) %}
        assert profile_job.wait().success, "Job failed: " + profile_job.url
        profile_data : dict[str, Any] = profile_job.download_profile()
        print_profile_metrics_from_job(profile_job, profile_data)
        {%- endfilter %}

    {% if not is_precompiled -%}
    if not skip_summary and {{ "not skip_inferencing" if is_collection_model else "inference_job is not None" }}:
        {%- if is_collection_model %}
        for component_name in components:
            component = model.components[component_name]

            inference_job = inference_jobs[component_name]
        {%- endif %}
        {%- filter indent(width=4 if is_collection_model else 0) %}
        sample_inputs = {{ model_var }}.sample_inputs({{ "input_specs[component_name], " if is_collection_model else "input_spec, "}}use_channel_last_format=False)
        torch_out = torch_inference(
            {{ model_var }}, sample_inputs, return_channel_last_output=target_runtime.channel_last_native_execution
        )
        assert inference_job.wait().success, "Job failed: " + inference_job.url
        inference_result = inference_job.download_output_data()
        assert inference_result is not None
        {% set skipped_outputs = ", outputs_to_skip=[" ~ outputs_to_skip_validation|join(", ") ~ "]" if outputs_to_skip_validation else "" -%}
        {% set inference_metrics = ", metrics=\"" ~ inference_metrics ~ "\"" if inference_metrics and inference_metrics != "psnr" else "" -%}
        print_inference_metrics(
            inference_job, inference_result, torch_out, {{ model_var }}.get_output_names(){{ skipped_outputs }}{{ inference_metrics }}
        )
        {%- endfilter %}
    {%- endif %}

    if not skip_summary:
        print_tool_versions(tool_versions, tool_versions_are_from_device_job)
        {% if print_demo_cmd -%}
        print_on_target_demo_cmd(
            link_job{{"s.values()" if is_collection_model}} if link_job{{ optional_s }} else compile_job{{"s.values()" if is_collection_model}}, Path(__file__).parent, device
        )
        {%- endif %}

    if downloaded_model_path:
        print(f"{model_name} was saved to {downloaded_model_path}\n")

    {% if add_genie_url_to_export -%}
    print("These models can be deployed on-device using the Genie SDK. For a full tutorial, please follow the instructions here: https://github.com/quic/ai-hub-apps/tree/main/tutorials/llm_on_genie.")
    {%- endif %}

    {% if is_collection_model -%}
    return CollectionExportResult(
        components={
            component_name: ExportResult(
                {%- if not is_precompiled %}
                compile_job=compile_jobs[component_name],
                link_job=link_jobs.get(component_name) if link_jobs else None,
                inference_job=inference_jobs.get(component_name, None),
                {%- endif %}
                profile_job=profile_jobs.get(component_name, None),
                {%- if can_use_quantize_job %}
                quantize_job=quantize_jobs.get(component_name, None),
                {%- endif %}
            )
            for component_name in components
        },
        download_path=downloaded_model_path,
        tool_versions=tool_versions
    )
    {%- else -%}
    return ExportResult(
        {%- if not is_precompiled %}
        compile_job=compile_job,
        link_job=link_job,
        inference_job=inference_job,
        {%- endif %}
        profile_job=profile_job,
        {%- if can_use_quantize_job %}
        quantize_job=quantize_job,
        {%- endif %}
        download_path=downloaded_model_path,
        tool_versions=tool_versions,
    )
    {%- endif %}

def main() -> None:
    warnings.filterwarnings("ignore")
{%- if model_status != "published" %}
    if not check_unpublished_model_warning():
        return
{%- endif %}
    supported_precision_runtimes : {{ common.write_supported_precision_runtimes(supported_precision_runtimes) }}

    parser = export_parser(
        model_cls=Model,
        export_fn=export_model,
        supported_precision_runtimes=supported_precision_runtimes,
        {{- "components=ALL_COMPONENTS," if has_components else "" -}}
        default_export_device="{{ default_device }}",
        {{- "force_fetch_static_assets=True," if freeze_perf_yaml else "" -}}
    )
    args = parser.parse_args()
    export_model(**vars(args))

if __name__ == "__main__":
    main()
