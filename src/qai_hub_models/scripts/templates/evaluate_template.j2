{% import 'common_template.j2' as common %}
{{ header }}


from __future__ import annotations

import argparse
import warnings

from qai_hub_models import Precision, TargetRuntime
from qai_hub_models.models.{{ model_name }} import MODEL_ID, Model
{%- if model_status != "published" %}
from qai_hub_models.utils.asset_loaders import check_unpublished_model_warning
{%- endif %}
from qai_hub_models.utils.args import evaluate_parser
from qai_hub_models.utils.evaluate.dispatch import select_evaluate_pipeline
from qai_hub_models.utils.export.dispatch import resolve_model


SUPPORTED_PRECISION_RUNTIMES: {{ common.write_supported_precision_runtimes(supported_precision_runtimes) }}

DEFAULT_EVAL_DEVICE = "{{ default_device }}"

evaluate_model = select_evaluate_pipeline(resolve_model(MODEL_ID))


def build_parser() -> argparse.ArgumentParser:
    """Build the argparse parser for this model's evaluate script.

    Exposed so the qai-hub-models CLI dispatcher can reuse the model's native
    parser without re-running main().
    """
    return evaluate_parser(
        model_cls=Model,
        supported_dataset_classes=Model.get_eval_dataset_classes(),
        supported_precision_runtimes=SUPPORTED_PRECISION_RUNTIMES,
        {%- if not can_use_quantize_job or not supports_quantization %}
        uses_quantize_job=False,
        {%- endif %}
        {%- if can_use_quantize_job and supports_quantization and num_calibration_samples %}
        num_calibration_samples={{ num_calibration_samples }},
        {%- endif %}
        default_device=DEFAULT_EVAL_DEVICE,
    )


def main(args: argparse.Namespace | None = None) -> None:
{%- if model_status != "published" %}
    if not check_unpublished_model_warning():
        return
{%- endif %}
    if args is None:
        warnings.warn(
            "Running `python -m qai_hub_models.models.{{ model_name }}.evaluate` is "
            "deprecated and will be removed in a future release. "
            "Use `qai-hub-models evaluate {{ model_name }}` instead.",
            DeprecationWarning,
            stacklevel=2,
        )
        args = build_parser().parse_args()
    evaluate_model(MODEL_ID, **vars(args))


if __name__ == "__main__":
    main()
