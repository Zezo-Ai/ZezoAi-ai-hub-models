{#
    Model README Template

    Generates the README.md for each model in the qai_hub_models repository.
    Includes installation instructions, usage examples, and model documentation.
#}
{% from 'shared/readme_macros.j2' import model_intro, license, references, community, usage_and_limitations, example_and_usage, download_assets, deploying_on_device %}
{#
    Render the model README.

    Parameters
    ----------
    model_name : str
        Display name of the model.
    model_headline : str
        Short description for the title.
    model_url : str
        URL to the model page on AI Hub.
    model_description : str
        Full model description.
    source_repo : str
        URL to the original repository this model was sourced from.
    license_url : str
        URL to the license file.
    research_paper_title : str
        Title of the research paper.
    research_paper_url : str
        URL to the research paper.
    include_gen_ai_terms : bool
        Whether to include generative AI usage limitations.
    additional_readme_section : str
        Additional content to include in the README.
    voice_ai_sdk : VOICE_AI_SDK | None
        Which Qualcomm Voice AI SDK variant the model is compatible with (or
        None if the model has no Voice AI SDK integration).
    voice_ai_url : str | None
        URL to the corresponding Qualcomm Voice AI SDK download page.
    include_example_and_usage : bool
        Whether to include example and usage section.
    model_id : str, optional
        Model identifier (e.g., "resnet50").
    model_package : str, optional
        Python package path.
    supported_precisions : list[str], optional
        List of supported precisions.
    has_on_target_demo : bool, optional
        Whether the model supports on-device demo.
    has_model_requirements : bool, optional
        Whether model has additional pip requirements.
    pip_pre_build_reqs : str, optional
        Pre-build pip requirements.
    pip_install_flags : str, optional
        Additional pip install flags.
    pip_install_flags_gpu : str, optional
        GPU-specific pip install flags.
    python_version_gte : str, optional
        Minimum Python version.
    python_version_lt : str, optional
        Maximum Python version.
    readme_install_system_deps : str, optional
        Text describing system-level dependencies to install.
    readme_export_device : str, optional
        When set, appends ``--device "<value>"`` to the README export command.
        Derived from ``requires_aot_prepare`` in manifest.yaml.
    model_assets_shareable : bool, optional
        Whether pre-exported assets may be shared. When True, a "Download
        pre-exported assets" section is added near the top. Derived from the
        negation of ``restrict_model_sharing`` in manifest.yaml.
#}
{% macro render(
    model_name,
    model_headline,
    model_url,
    model_description,
    source_repo,
    license_url,
    research_paper_title,
    research_paper_url,
    include_gen_ai_terms,
    additional_readme_section,
    voice_ai_sdk,
    voice_ai_url,
    include_example_and_usage,
    model_id=None,
    model_package=None,
    supported_precisions=None,
    has_on_target_demo=False,
    has_model_requirements=False,
    pip_pre_build_reqs=None,
    pip_install_flags=None,
    pip_install_flags_gpu=None,
    python_version_gte=None,
    python_version_lt=None,
    readme_install_system_deps=None,
    readme_export_device=None,
    local_device_deployment=False,
    model_status="published",
    unpublished_model_warning="",
    model_assets_shareable=False,
    default_runtime=None,
    default_precision=None,
    separate_quantize_script=False,
    has_geniex_runtime=False,
    needs_local_export=False,
    has_genie_runtime=False,
    geniex_url="",
    geniex_quickstart_url="",
    genie_url=""
) %}
{% if model_status != "published" %}
> [!WARNING]
> {{ unpublished_model_warning }}

{% endif %}
# [{{ model_name }}: {{ model_headline }}]({{ model_url }})

{{ model_description }}

{{ model_intro(model_name, source_repo, model_url) }}

{{ download_assets(model_name, model_assets_shareable, default_runtime, default_precision) }}
{% if additional_readme_section %}

{{ additional_readme_section }}
{% endif %}
{% if has_geniex_runtime %}

{{ deploying_on_device(model_name, needs_local_export, has_genie_runtime, geniex_url, geniex_quickstart_url, genie_url) }}
{% endif %}
{% if voice_ai_sdk %}

## Deploying {{ model_name }} on-device

This model is compatible with the Qualcomm Voice AI SDK. Download the SDK from the [Qualcomm Package Manager]({{ voice_ai_url }}) to deploy this model on-device.
{% endif %}
{% if include_example_and_usage %}

{{ example_and_usage(model_id, model_package, supported_precisions, has_on_target_demo, has_model_requirements, pip_pre_build_reqs, pip_install_flags, pip_install_flags_gpu, python_version_gte, python_version_lt, readme_install_system_deps, readme_export_device=readme_export_device, local_device_deployment=local_device_deployment, default_runtime=default_runtime, default_precision=default_precision, separate_quantize_script=separate_quantize_script) }}
{% endif %}

{{ license(model_name, license_url) }}

{{ references(research_paper_title, research_paper_url, source_repo) }}

{{ community() }}
{% if include_gen_ai_terms %}

{{ usage_and_limitations() }}
{% endif %}
{% endmacro %}
