# Trace the model & upload to hub only once for all module + input pairs.
# This speeds up tests and limits memory leaks for torch jit trace.
@pytest.fixture(scope="module", autouse=True)
def cached_torch_trace_for_export() -> Generator[pytest.MonkeyPatch, None, None]:
    with pytest.MonkeyPatch.context() as mp:
        model_cache: dict[str, hub.Model] = {}

        {%- if is_aimet %}
        convert_to_hub_source_model = BaseModel.convert_to_hub_source_model
        def _cached_convert_to_hub_source_model(
            self: BaseModel,
            target_runtime: TargetRuntime,
            output_path: str | Path,
            input_spec: InputSpec | None = None,
            check_trace: bool = True,
        ) -> SourceModel | hub.Model:
            source_model_format = self.preferred_hub_source_model_format(target_runtime)
            model_key = str(self) + str(input_spec) + str(source_model_format)
            model = model_cache.get(model_key, None)
            if not model:
                source_model = convert_to_hub_source_model(
                    self, target_runtime, output_path, input_spec, check_trace
                )
                assert source_model is not None
                model = hub.upload_model(source_model)
                model_cache[model_key] = model
            return model

        mp.setattr(BaseModel, "convert_to_hub_source_model", _cached_convert_to_hub_source_model)
        {%- else %}
        {%- set serial_name = "trace" if not enable_pt2 else "export" %}
        {%- if enable_pt2 %}
        torch_{{ serial_name }} = torch.export.export
        {%- else %}
        torch_{{ serial_name }} = torch.jit.trace
        {%- endif %}
        {% if torchscript_opt %}
        optimize_for_mobile = mobile_optimizer.optimize_for_mobile
        {% endif %}
        def _cached_torch_{{ serial_name }}(module: torch.nn.Module, inputs: torch.Tensor | tuple[torch.Tensor, ...]{{ ", check_trace: bool=True" if not enable_pt2 else "" }}) -> hub.Model:
            model_key = str(module) + str(sorted([f"{x.shape}{x.type()}" for x in inputs]))
            model = model_cache.get(model_key, None)
            if not model:
                {%- if enable_pt2 %}
                {{ serial_name }} = torch_{{ serial_name }}(module, inputs) # type: ignore[arg-type]
                {%- else %}
                {{ serial_name }} = torch_{{ serial_name }}(module, inputs, check_trace=check_trace)
                {%- endif %}
                {%- if torchscript_opt %}
                {{ serial_name }} = optimize_for_mobile(
                    {{ serial_name }},
                    optimization_blocklist={
                        {% for opt in torchscript_opt %}
                        mobile_optimizer.MobileOptimizerType.{{ opt }},  # type: ignore[attr-defined]
                        {% endfor %}
                    },
                )
                {%- endif %}
                model = hub.upload_model({{ serial_name }})
                model_cache[model_key] = model
            assert isinstance(model, hub.Model)
            return model

        {%- if enable_pt2 %}
        mp.setattr(model_export_module.torch.export, "export", _cached_torch_{{ serial_name }})
        {%- else %}
        mp.setattr(model_export_module.torch.jit, "trace", _cached_torch_{{ serial_name }})
        {%- endif %}
        {%- endif %}
        {% if torchscript_opt -%}
        def _dummy_optimize_for_mobile(model: torch.jit.ScriptModule, *args: Any, **kwargs: Any) -> torch.jit.ScriptModule:
            return model
        mp.setattr(mobile_optimizer, "optimize_for_mobile", _dummy_optimize_for_mobile)
        {% endif -%}
        yield mp
